# ─── Rekenhet.nl Environment Variables ─────────────────────────────
# Copy this file to .env.local and fill in your values.

# Google AdSense Publisher ID
NEXT_PUBLIC_ADSENSE_ID=ca-pub-xxxxxxxxxxxxxx
NEXT_PUBLIC_AD_SLOT_SIDEBAR=1234567891
NEXT_PUBLIC_AD_SLOT_INLINE=1234567892
NEXT_PUBLIC_AD_SLOT_ANCHOR=1234567893
NEXT_PUBLIC_AD_SLOT_ABOVE=1234567890

NEXT_PUBLIC_SITE_URL=https://www.rekenhet.nl

# Google Site Verification (for Search Console)
NEXT_PUBLIC_GOOGLE_VERIFICATION=your-google-site-verification-code

# ─── Email (Resend) ───────────────────────────────────────────────
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Resend Audience ID for newsletter subscriptions
# Create an Audience in Resend dashboard and paste the ID here
RESEND_AUDIENCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Default "from" address for transactional emails
# Must be a verified domain in Resend
EMAIL_FROM=Rekenhet.nl <noreply@rekenhet.nl>

# ─── Revalidation ────────────────────────────────────────────────
# Token to secure the /api/revalidate endpoint
# Use a long, random string. Set to empty to disable auth check.
REVALIDATION_TOKEN=your-secret-revalidation-token

# ─── Analytics (Telemetry) ──────────────────────────────────────
# Plausible (self-hosted or cloud)
# PLAUSIBLE_URL=https://plausible.example.com
# PLAUSIBLE_DOMAIN=rekenhet.nl

# Umami (self-hosted or cloud)
# UMAMI_URL=https://umami.example.com
# UMAMI_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# UMAMI_API_KEY=xxxxx
